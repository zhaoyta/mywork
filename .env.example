# LLM & Embedding API
# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# EMBED_MODEL=text-embedding-3-small

# --- DeepSeek（推荐，价格低，兼容 OpenAI 接口）---
OPENAI_API_KEY=sk-...                       # DeepSeek API Key（从 platform.deepseek.com 获取）
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
EMBED_MODEL=local                           # DeepSeek 暂无 embedding API，用本地 bge 模型

# Local embed model path (used when EMBED_MODEL=local)
LOCAL_EMBED_MODEL=BAAI/bge-small-zh-v1.5

# OCR engine: "paddleocr" (default) or "tesseract"
OCR_ENGINE=paddleocr

# Logging level: DEBUG / INFO / WARNING
LOG_LEVEL=INFO
